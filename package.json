{
  "name": "ai-trade-simulator-bot",
  "version": "1.0.0",
  "description": "Telegram paper-trading bot with MEXC market data and AI strategy selection",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
